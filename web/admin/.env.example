# Codohue Admin frontend env (Vite-scoped)
# ----------------------------------------------------------------------------
# Copy this file to `web/admin/.env` for local overrides.
# `.env` is gitignored; `.env.example` (this file) is tracked.
#
# IMPORTANT: only variables prefixed with VITE_ are exposed to client code via
# import.meta.env.VITE_*. Variables without the prefix stay invisible to the
# browser. Server-side secrets (DATABASE_URL, RECOMMENDER_API_KEY, etc.) live
# in the project root `.env` and must NEVER be copied here — they would leak
# into the production SPA bundle and DevTools.
#
# Vite does NOT auto-inject env into vite.config.ts. The values below that
# affect Vite itself (dev port, proxy target) are read explicitly via
# loadEnv() in vite.config.ts. The VITE_ADMIN_API_BASE_URL is consumed by
# the SPA at runtime through import.meta.env.

# Admin API base URL the SPA calls into.
#
# Default (empty string) is the right answer for both supported deploy modes:
#   - dev:  the Vite dev server proxies /api -> VITE_ADMIN_PROXY_TARGET (see
#           below), so fetch('/api/...') just works.
#   - prod: the SPA is embedded into the admin Go binary at web/admin/dist/,
#           served from the same origin as the API, so relative URLs work.
#
# Set this only when the dev server should target a remote admin instance
# (e.g. a staging deploy), for example:
#   VITE_ADMIN_API_BASE_URL=https://admin.staging.codohue.example
VITE_ADMIN_API_BASE_URL=

# Vite dev server port (the address you load in the browser).
# Default: 5174
VITE_ADMIN_DEV_PORT=5174

# Where vite's dev proxy forwards /api requests. This is the cmd/admin server
# (default port 2002 — see ADMIN_PORT in the project root .env).
# Default: http://localhost:2002
VITE_ADMIN_PROXY_TARGET=http://localhost:2002
