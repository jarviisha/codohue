DATABASE_URL=postgres://codohue:secret@localhost:5432/codohue?sslmode=disable
REDIS_URL=redis://localhost:6379
QDRANT_HOST=localhost
QDRANT_PORT=6334
CODOHUE_ADMIN_API_KEY=dev-secret-key
CODOHUE_BATCH_INTERVAL_MINUTES=5
CODOHUE_LOG_FORMAT=text
CODOHUE_API_PORT=2001
CODOHUE_ADMIN_PORT=2002
CODOHUE_API_URL=http://localhost:2001

# Retention (cmd/cron) — set days to 0 to disable a given prune.
CODOHUE_BATCH_RUN_RETENTION_DAYS=30
CODOHUE_BACKLOG_SAMPLES_RETENTION_DAYS=7
CODOHUE_RETENTION_INTERVAL=1h

# Catalog auto-embedding (cmd/embedder)
CODOHUE_CATALOG_MAX_CONTENT_BYTES=32768
CODOHUE_EMBED_MAX_ATTEMPTS=5
CODOHUE_EMBEDDER_HEALTH_PORT=2003
CODOHUE_EMBEDDER_REPLICA_NAME=
CODOHUE_EMBEDDER_POLL_INTERVAL=30s

# ── Production deploy (docker-compose.prod.yml) ─────────────────────────────
# These are read by docker compose on the VPS (/opt/codohue/.env), not by the
# binaries in development. Everything above this section is dev-only.
#
# CODOHUE_ADMIN_API_KEY is required in both modes (reuses the dev key above
# locally; set a strong value on the VPS).
#
# Image tag to deploy; the CD pipeline overrides this per release.
#IMAGE_TAG=latest
#
# Database — pick ONE of the two modes:
#
# Mode A (default): externally managed Postgres. From inside a container,
# "localhost" is the container itself — if Postgres runs on the VPS host,
# use the docker bridge IP (e.g. 172.17.0.1) instead.
#CODOHUE_DATABASE_URL=postgres://codohue:secret@db-host:5432/codohue?sslmode=disable
#
# Mode B: run Postgres inside the compose stack. DATABASE_URL then defaults
# to the bundled postgres service — do not set CODOHUE_DATABASE_URL.
# The password is interpolated into a postgres:// URL, so it must not
# contain URL-reserved characters (@ : / ? # % [ ]) — stick to letters,
# digits, - and _.
#COMPOSE_PROFILES=local-db
#CODOHUE_POSTGRES_PASSWORD=change-me
#
# Host-published ports. When dev and prod stacks share one host
# (/opt/codohue-dev + /opt/codohue-prod), give each stack its own set —
# e.g. leave prod on the defaults and shift dev to 3001/3002/3003/...
#CODOHUE_API_PUBLISHED_PORT=2001
#CODOHUE_ADMIN_PUBLISHED_PORT=2002
#CODOHUE_EMBEDDER_PUBLISHED_PORT=2003
#CODOHUE_QDRANT_HTTP_PUBLISHED_PORT=6333
#CODOHUE_QDRANT_GRPC_PUBLISHED_PORT=6334
#CODOHUE_POSTGRES_PUBLISHED_PORT=5432
